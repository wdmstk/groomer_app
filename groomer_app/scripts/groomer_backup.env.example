# Copy this file to /etc/groomer_backup.env and set real values.
# Recommended permissions:
#   sudo chown root:root /etc/groomer_backup.env
#   sudo chmod 600 /etc/groomer_backup.env

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@YOUR_DB_HOST:6543/postgres?sslmode=require

# Optional (default: pet-photos)
SUPABASE_UPLOAD_BUCKET=pet-photos

# Backup destination root
BACKUP_DIR=/var/backups/groomer_app
